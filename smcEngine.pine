//@version=6
indicator("SMC Engine - Professional", overlay=true, max_bars_back=500)

// ============================================================================
// STRATEGY TOGGLE (COMMENT OUT FOR INDICATOR MODE)
// ============================================================================

isStrategy = false

// ============================================================================
// INPUTS
// ============================================================================

// Risk Management
riskPercent = input.float(1.0, title="Risk %", minval=0.1, maxval=5, step=0.1, group="Risk Management")
minRR = input.float(2.0, title="Min RR", minval=1.0, maxval=10, step=0.5, group="Risk Management")
prefRR = input.float(3.0, title="Preferred RR", minval=1.5, maxval=10, step=0.5, group="Risk Management")

// SMC Parameters
swingWindow = input.int(3, title="Swing Window", minval=2, maxval=5, group="SMC")
fvgThreshold = input.float(0.0007, title="FVG Threshold %", minval=0.0001, maxval=0.01, step=0.0001, group="SMC")
eqhEqlThreshold = input.float(0.0007, title="EQH/EQL Threshold %", minval=0.0001, maxval=0.01, step=0.0001, group="SMC")
lookbackWindow = input.int(60, title="Lookback Window", minval=20, maxval=200, group="SMC")

// Display
showSwings = input.bool(true, title="Show Swings", group="Display")
showFVG = input.bool(true, title="Show FVG", group="Display")
showOB = input.bool(true, title="Show Order Blocks", group="Display")
showStructure = input.bool(true, title="Show BOS/CHOCH", group="Display")
showSweeps = input.bool(true, title="Show Sweeps", group="Display")
showEQ = input.bool(true, title="Show EQH/EQL", group="Display")
showSignals = input.bool(true, title="Show Signals", group="Display")
showTable = input.bool(true, title="Show Info Table", group="Display")

// ============================================================================
// GLOBAL VARIABLES
// ============================================================================

var array<chart.point> swingHighs = array.new<chart.point>()
var array<chart.point> swingLows = array.new<chart.point>()

var float lastHighTarget = na
var float lastLowTarget = na
var string marketTrend = "BULLISH"

var float lastBuyEntry = na
var float lastBuySL = na
var float lastBuyTP = na
var float lastBuyRR = na
var int lastBuyBar = na
var bool buyActive = false

var float lastSellEntry = na
var float lastSellSL = na
var float lastSellTP = na
var float lastSellRR = na
var int lastSellBar = na
var bool sellActive = false

var bool lastWasBullishChoch = false
var bool lastWasBearishChoch = false
var bool lastWasBullishBOS = false
var bool lastWasBearishBOS = false

var int lastFVGBarB = na
var int lastFVGBarS = na
var int lastOBBarB = na
var int lastOBBarS = na
var int lastSSLBar = na
var int lastBSLBar = na

// ============================================================================
// DETECT SWING HIGHS & LOWS
// ============================================================================

f_detectSwings() =>
    p = swingWindow
    
    if bar_index >= p * 2
        isHigh = true
        for j = 1 to p
            if high[j] > high[0] or high[j] >= high[0]
                isHigh := false
                break
        
        if isHigh
            array.push(swingHighs, chart.point.new(bar_index, high[0]))
        
        isLow = true
        for j = 1 to p
            if low[j] < low[0] or low[j] <= low[0]
                isLow := false
                break
        
        if isLow
            array.push(swingLows, chart.point.new(bar_index, low[0]))
    
    if array.size(swingHighs) > 100
        array.shift(swingHighs)
    if array.size(swingLows) > 100
        array.shift(swingLows)

// ============================================================================
// DETECT FAIR VALUE GAPS (FVG)
// ============================================================================

f_detectFVGs() =>
    bullishFVG = false
    bearishFVG = false
    
    if bar_index >= 2
        // Bullish FVG
        if high[2] < low[0] and close[1] > open[1]
            bullishFVG := true
            lastFVGBarB := bar_index
        
        // Bearish FVG
        if low[2] > high[0] and close[1] < open[1]
            bearishFVG := true
            lastFVGBarS := bar_index
    
    [bullishFVG, bearishFVG]

// ============================================================================
// DETECT ORDER BLOCKS (OB)
// ============================================================================

f_detectOrderBlocks() =>
    bullishOB = false
    bearishOB = false
    obHighB = 0.0
    obLowB = 0.0
    obHighS = 0.0
    obLowS = 0.0
    
    if bar_index >= 2
        // Bullish OB (Bearish candle before bullish expansion)
        if close[1] < open[1] and high[2] < low[0]
            bullishOB := true
            obHighB := high[1]
            obLowB := low[1]
            lastOBBarB := bar_index - 1
        
        // Bearish OB (Bullish candle before bearish collapse)
        if close[1] > open[1] and low[2] > high[0]
            bearishOB := true
            obHighS := high[1]
            obLowS := low[1]
            lastOBBarS := bar_index - 1
    
    [bullishOB, bearishOB, obHighB, obLowB, obHighS, obLowS]

// ============================================================================
// DETECT LIQUIDITY SWEEPS
// ============================================================================

f_detectSweeps() =>
    sslSweep = false
    bslSweep = false
    
    if array.size(swingHighs) > 0
        recentHigh = array.get(swingHighs, array.size(swingHighs) - 1)
        if not na(recentHigh.y) and bar_index - recentHigh.x > 1 and bar_index - recentHigh.x < 60
            if high > recentHigh.y and close <= recentHigh.y
                bslSweep := true
                lastBSLBar := bar_index
    
    if array.size(swingLows) > 0
        recentLow = array.get(swingLows, array.size(swingLows) - 1)
        if not na(recentLow.y) and bar_index - recentLow.x > 1 and bar_index - recentLow.x < 60
            if low < recentLow.y and close >= recentLow.y
                sslSweep := true
                lastSSLBar := bar_index
    
    [sslSweep, bslSweep]

// ============================================================================
// DETECT BOS & CHOCH
// ============================================================================

f_detectStructures() =>
    if array.size(swingHighs) > 0 and array.size(swingLows) > 0
        recentHighs = array.new<chart.point>()
        recentLows = array.new<chart.point>()
        
        for i = 0 to math.min(array.size(swingHighs) - 1, 30)
            sh = array.get(swingHighs, array.size(swingHighs) - 1 - i)
            if bar_index - sh.x < lookbackWindow and bar_index - sh.x > 0
                array.push(recentHighs, sh)
        
        for i = 0 to math.min(array.size(swingLows) - 1, 30)
            sl = array.get(swingLows, array.size(swingLows) - 1 - i)
            if bar_index - sl.x < lookbackWindow and bar_index - sl.x > 0
                array.push(recentLows, sl)
        
        if array.size(recentHighs) > 0
            highestRecent = array.get(recentHighs, 0)
            for i = 1 to array.size(recentHighs) - 1
                candidate = array.get(recentHighs, i)
                if candidate.y > highestRecent.y
                    highestRecent := candidate
            lastHighTarget := highestRecent.y
        
        if array.size(recentLows) > 0
            lowestRecent = array.get(recentLows, 0)
            for i = 1 to array.size(recentLows) - 1
                candidate = array.get(recentLows, i)
                if candidate.y < lowestRecent.y
                    lowestRecent := candidate
            lastLowTarget := lowestRecent.y
        
        // Bullish BOS/CHOCH
        if not na(lastHighTarget) and close > lastHighTarget
            if marketTrend == "BEARISH"
                lastWasBullishChoch := true
                marketTrend := "BULLISH"
            else
                lastWasBullishBOS := true
            lastHighTarget := na
        
        // Bearish BOS/CHOCH
        if not na(lastLowTarget) and close < lastLowTarget
            if marketTrend == "BULLISH"
                lastWasBearishChoch := true
                marketTrend := "BEARISH"
            else
                lastWasBearishBOS := true
            lastLowTarget := na

// ============================================================================
// DETECT EQUAL HIGHS & LOWS
// ============================================================================

f_detectEqualPrices() =>
    eqhPrice = 0.0
    eqlPrice = 0.0
    hasEQH = false
    hasEQL = false
    
    if array.size(swingHighs) > 1
        for i = 0 to math.min(array.size(swingHighs) - 2, 20)
            h1 = array.get(swingHighs, i)
            if i + 1 < array.size(swingHighs)
                h2 = array.get(swingHighs, i + 1)
                
                if h2.x - h1.x <= lookbackWindow and h2.x - h1.x > 0
                    avg = (h1.y + h2.y) / 2
                    pctDiff = math.abs(h1.y - h2.y) / avg
                    
                    if pctDiff < eqhEqlThreshold
                        eqhPrice := avg
                        hasEQH := true
                        break
    
    if array.size(swingLows) > 1
        for i = 0 to math.min(array.size(swingLows) - 2, 20)
            l1 = array.get(swingLows, i)
            if i + 1 < array.size(swingLows)
                l2 = array.get(swingLows, i + 1)
                
                if l2.x - l1.x <= lookbackWindow and l2.x - l1.x > 0
                    avg = (l1.y + l2.y) / 2
                    pctDiff = math.abs(l1.y - l2.y) / avg
                    
                    if pctDiff < eqhEqlThreshold
                        eqlPrice := avg
                        hasEQL := true
                        break
    
    [hasEQH, hasEQL, eqhPrice, eqlPrice]

// ============================================================================
// GENERATE TRADING SIGNALS
// ============================================================================

f_generateSignals(sslSweep, bslSweep, bullishOB, bearishOB, obHighB, obLowB, obHighS, obLowS) =>
    if not buyActive and sslSweep and lastWasBullishChoch and bullishOB and low <= obHighB and high >= obLowB
        entry = close
        sl = obLowB * 0.9985
        tp = entry + (entry - sl) * prefRR
        rr = (entry - sl) / (tp - entry)
        
        if rr >= minRR and rr <= 10
            lastBuyEntry := entry
            lastBuySL := sl
            lastBuyTP := tp
            lastBuyRR := rr
            lastBuyBar := bar_index
            buyActive := true
            lastWasBullishChoch := false
    
    if not sellActive and bslSweep and lastWasBearishChoch and bearishOB and low <= obHighS and high >= obLowS
        entry = close
        sl = obHighS * 1.0015
        tp = entry - (sl - entry) * prefRR
        rr = (sl - entry) / (entry - tp)
        
        if rr >= minRR and rr <= 10
            lastSellEntry := entry
            lastSellSL := sl
            lastSellTP := tp
            lastSellRR := rr
            lastSellBar := bar_index
            sellActive := true
            lastWasBearishChoch := false

// ============================================================================
// CHECK EXIT CONDITIONS
// ============================================================================

f_checkExits() =>
    if buyActive
        if close < lastBuySL
            buyActive := false
            if isStrategy
                strategy.close("Buy", alert_message="BUY SL Hit")
        
        if close > lastBuyTP
            buyActive := false
            if isStrategy
                strategy.close("Buy", alert_message="BUY TP Hit")
        
        if marketTrend == "BEARISH"
            buyActive := false
            if isStrategy
                strategy.close("Buy", alert_message="Bearish Turn")
    
    if sellActive
        if close > lastSellSL
            sellActive := false
            if isStrategy
                strategy.close("Sell", alert_message="SELL SL Hit")
        
        if close < lastSellTP
            sellActive := false
            if isStrategy
                strategy.close("Sell", alert_message="SELL TP Hit")
        
        if marketTrend == "BULLISH"
            sellActive := false
            if isStrategy
                strategy.close("Sell", alert_message="Bullish Turn")

// ============================================================================
// EXECUTE DETECTION
// ============================================================================

f_detectSwings()
[bullishFVG, bearishFVG] = f_detectFVGs()
[bullishOB, bearishOB, obHighB, obLowB, obHighS, obLowS] = f_detectOrderBlocks()
[sslSweep, bslSweep] = f_detectSweeps()
f_detectStructures()
[hasEQH, hasEQL, eqhPrice, eqlPrice] = f_detectEqualPrices()
f_generateSignals(sslSweep, bslSweep, bullishOB, bearishOB, obHighB, obLowB, obHighS, obLowS)
f_checkExits()

// ============================================================================
// DRAWING: SWING POINTS
// ============================================================================

if showSwings
    if array.size(swingHighs) > 0
        for i = math.max(0, array.size(swingHighs) - 20) to array.size(swingHighs) - 1
            sh = array.get(swingHighs, i)
            label.new(sh.x, sh.y, "H", color=color.new(color.green, 0), style=label.style_diamond, size=size.tiny, textcolor=color.white)
    
    if array.size(swingLows) > 0
        for i = math.max(0, array.size(swingLows) - 20) to array.size(swingLows) - 1
            sl = array.get(swingLows, i)
            label.new(sl.x, sl.y, "L", color=color.new(color.red, 0), style=label.style_diamond, size=size.tiny, textcolor=color.white)

// ============================================================================
// DRAWING: FVG
// ============================================================================

if showFVG
    if not na(lastFVGBarB) and bar_index - lastFVGBarB < 100
        box.new(lastFVGBarB - 1, high[bar_index - lastFVGBarB + 1], bar_index + 20, low[bar_index - lastFVGBarB], bgcolor=color.new(color.green, 85), border_color=na)
    
    if not na(lastFVGBarS) and bar_index - lastFVGBarS < 100
        box.new(lastFVGBarS - 1, high[bar_index - lastFVGBarS], bar_index + 20, low[bar_index - lastFVGBarS + 1], bgcolor=color.new(color.red, 85), border_color=na)

// ============================================================================
// DRAWING: ORDER BLOCKS
// ============================================================================

if showOB
    if not na(lastOBBarB) and bar_index - lastOBBarB < 100
        box.new(lastOBBarB, lastBuySL, bar_index + 50, lastBuyEntry + (lastBuyEntry - lastBuySL), bgcolor=color.new(color.blue, 80), border_color=na)
    
    if not na(lastOBBarS) and bar_index - lastOBBarS < 100
        box.new(lastOBBarS, lastSellEntry - (lastSellSL - lastSellEntry), bar_index + 50, lastSellSL, bgcolor=color.new(color.orange, 80), border_color=na)

// ============================================================================
// DRAWING: STRUCTURES (BOS/CHOCH)
// ============================================================================

if showStructure
    if lastWasBullishChoch
        line.new(bar_index - 30, lastHighTarget, bar_index, lastHighTarget, color=color.new(color.green, 0), width=2, style=line.style_dashed)
    
    if lastWasBearishChoch
        line.new(bar_index - 30, lastLowTarget, bar_index, lastLowTarget, color=color.new(color.red, 0), width=2, style=line.style_dashed)

// ============================================================================
// DRAWING: SWEEPS
// ============================================================================

if showSweeps
    if not na(lastSSLBar) and bar_index - lastSSLBar < 50
        label.new(lastSSLBar, low + (high - low) * 0.5, "SSL", color=color.new(color.lime, 0), style=label.style_label_down, size=size.small, textcolor=color.black)
    
    if not na(lastBSLBar) and bar_index - lastBSLBar < 50
        label.new(lastBSLBar, high - (high - low) * 0.5, "BSL", color=color.new(color.purple, 0), style=label.style_label_up, size=size.small, textcolor=color.white)

// ============================================================================
// DRAWING: EQUAL HIGHS & LOWS
// ============================================================================

if showEQ
    if hasEQH
        line.new(bar_index - 50, eqhPrice, bar_index, eqhPrice, color=color.new(color.green, 40), width=1, style=line.style_dotted)
    
    if hasEQL
        line.new(bar_index - 50, eqlPrice, bar_index, eqlPrice, color=color.new(color.red, 40), width=1, style=line.style_dotted)

// ============================================================================
// DRAWING: TRADE SIGNALS
// ============================================================================

if showSignals
    if buyActive
        label.new(lastBuyBar, lastBuySL - (lastBuySL - lastBuyEntry) * 0.1, "BUY\n" + str.tostring(lastBuyEntry, "0.00000"), color=color.new(color.green, 0), style=label.style_label_up, size=size.small, textcolor=color.white)
        line.new(lastBuyBar, lastBuySL, bar_index, lastBuySL, color=color.new(color.red, 0), width=1, style=line.style_dashed)
        line.new(lastBuyBar, lastBuyTP, bar_index, lastBuyTP, color=color.new(color.green, 0), width=1, style=line.style_dashed)
    
    if sellActive
        label.new(lastSellBar, lastSellSL + (lastSellSL - lastSellEntry) * 0.1, "SELL\n" + str.tostring(lastSellEntry, "0.00000"), color=color.new(color.red, 0), style=label.style_label_down, size=size.small, textcolor=color.white)
        line.new(lastSellBar, lastSellSL, bar_index, lastSellSL, color=color.new(color.red, 0), width=1, style=line.style_dashed)
        line.new(lastSellBar, lastSellTP, bar_index, lastSellTP, color=color.new(color.green, 0), width=1, style=line.style_dashed)

// ============================================================================
// ALERTS
// ============================================================================

if buyActive and barstate.isconfirmed
    alert("BUY: Entry=" + str.tostring(lastBuyEntry, "0.00000") + " SL=" + str.tostring(lastBuySL, "0.00000") + " TP=" + str.tostring(lastBuyTP, "0.00000") + " RR=" + str.tostring(lastBuyRR, "0.00"), alert.freq_once_per_bar)

if sellActive and barstate.isconfirmed
    alert("SELL: Entry=" + str.tostring(lastSellEntry, "0.00000") + " SL=" + str.tostring(lastSellSL, "0.00000") + " TP=" + str.tostring(lastSellTP, "0.00000") + " RR=" + str.tostring(lastSellRR, "0.00"), alert.freq_once_per_bar)

if lastWasBullishChoch and barstate.isconfirmed
    alert("Bullish CHOCH", alert.freq_once_per_bar)

if lastWasBearishChoch and barstate.isconfirmed
    alert("Bearish CHOCH", alert.freq_once_per_bar)

if sslSweep and barstate.isconfirmed
    alert("SSL Sweep Detected", alert.freq_once_per_bar)

if bslSweep and barstate.isconfirmed
    alert("BSL Sweep Detected", alert.freq_once_per_bar)

// ============================================================================
// STRATEGY MODE
// ============================================================================

if isStrategy
    if buyActive
        strategy.entry("Buy", strategy.long, alert_message="BUY Entry")
        strategy.exit("Buy Exit", "Buy", stop=lastBuySL, limit=lastBuyTP)
    
    if sellActive
        strategy.entry("Sell", strategy.short, alert_message="SELL Entry")
        strategy.exit("Sell Exit", "Sell", stop=lastSellSL, limit=lastSellTP)

// ============================================================================
// INFO TABLE
// ============================================================================

if showTable
    var table infoTable = table.new(position.top_right, 2, 10, bgcolor=color.new(color.black, 80), border_color=color.gray, frame_color=color.gray)
    
    table.cell(infoTable, 0, 0, "SMC ENGINE", text_color=color.white, bgcolor=color.new(color.blue, 50))
    table.cell(infoTable, 1, 0, "Status", text_color=color.white, bgcolor=color.new(color.blue, 50))
    
    table.cell(infoTable, 0, 1, "Trend", text_color=color.white)
    table.cell(infoTable, 1, 1, marketTrend, text_color=marketTrend=="BULLISH"?color.green:color.red)
    
    table.cell(infoTable, 0, 2, "Buy Active", text_color=color.white)
    table.cell(infoTable, 1, 2, buyActive?"YES":"NO", text_color=buyActive?color.green:color.gray)
    
    table.cell(infoTable, 0, 3, "Entry", text_color=color.white)
    table.cell(infoTable, 1, 3, buyActive?str.tostring(lastBuyEntry, "0.00000"):"-", text_color=color.white)
    
    table.cell(infoTable, 0, 4, "SL", text_color=color.white)
    table.cell(infoTable, 1, 4, buyActive?str.tostring(lastBuySL, "0.00000"):"-", text_color=color.red)
    
    table.cell(infoTable, 0, 5, "TP", text_color=color.white)
    table.cell(infoTable, 1, 5, buyActive?str.tostring(lastBuyTP, "0.00000"):"-", text_color=color.green)
    
    table.cell(infoTable, 0, 6, "RR", text_color=color.white)
    table.cell(infoTable, 1, 6, buyActive?str.tostring(lastBuyRR, "0.00"):"-", text_color=color.yellow)
    
    table.cell(infoTable, 0, 7, "Swings", text_color=color.white)
    table.cell(infoTable, 1, 7, "H:" + str.tostring(array.size(swingHighs)) + " L:" + str.tostring(array.size(swingLows)), text_color=color.white)
    
    table.cell(infoTable, 0, 8, "Last Sweep", text_color=color.white)
    table.cell(infoTable, 1, 8, not na(lastSSLBar)?"SSL":not na(lastBSLBar)?"BSL":"-", text_color=color.white)
    
    table.cell(infoTable, 0, 9, "Last Structure", text_color=color.white)
    table.cell(infoTable, 1, 9, lastWasBullishChoch?"B.CHOCH":lastWasBearishChoch?"S.CHOCH":lastWasBullishBOS?"B.BOS":lastWasBearishBOS?"S.BOS":"-", text_color=color.white)

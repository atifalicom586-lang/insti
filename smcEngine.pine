//@version=6
indicator("SMC Engine - Professional", overlay=true, max_bars_back=500)

// ============================================================================
// INPUTS
// ============================================================================

// Risk Management
riskPercent = input.float(1.0, title="Risk %", minval=0.1, maxval=5, step=0.1, group="Risk Management")
minRR = input.float(2.0, title="Min RR", minval=1.0, maxval=10, step=0.5, group="Risk Management")
prefRR = input.float(3.0, title="Preferred RR", minval=1.5, maxval=10, step=0.5, group="Risk Management")

// SMC Parameters
swingWindow = input.int(3, title="Swing Window", minval=2, maxval=5, group="SMC")
fvgThreshold = input.float(0.0007, title="FVG Threshold %", minval=0.0001, maxval=0.01, step=0.0001, group="SMC")
eqhEqlThreshold = input.float(0.0007, title="EQH/EQL Threshold %", minval=0.0001, maxval=0.01, step=0.0001, group="SMC")
lookbackWindow = input.int(60, title="Lookback Window", minval=20, maxval=200, group="SMC")

// Display
showSwings = input.bool(true, title="Show Swings", group="Display")
showFVG = input.bool(true, title="Show FVG", group="Display")
showOB = input.bool(true, title="Show Order Blocks", group="Display")
showStructure = input.bool(true, title="Show BOS/CHOCH", group="Display")
showSweeps = input.bool(true, title="Show Sweeps", group="Display")
showEQ = input.bool(true, title="Show EQH/EQL", group="Display")
showSignals = input.bool(true, title="Show Signals", group="Display")
showTable = input.bool(true, title="Show Info Table", group="Display")

// ============================================================================
// GLOBAL VARIABLES
// ============================================================================

var array<chart.point> swingHighs = array.new<chart.point>()
var array<chart.point> swingLows = array.new<chart.point>()

var float lastHighTarget = na
var float lastLowTarget = na
var string marketTrend = "BULLISH"

var float lastBuyEntry = na
var float lastBuySL = na
var float lastBuyTP = na
var float lastBuyRR = na
var int lastBuyBar = na
var bool buyActive = false

var float lastSellEntry = na
var float lastSellSL = na
var float lastSellTP = na
var float lastSellRR = na
var int lastSellBar = na
var bool sellActive = false

var bool lastWasBullishChoch = false
var bool lastWasBearishChoch = false
var bool lastWasBullishBOS = false
var bool lastWasBearishBOS = false

var float lastFVGTop = na
var float lastFVGBot = na
var int lastFVGBarB = na
var int lastFVGBarS = na
var float lastFVGTopS = na
var float lastFVGBotS = na

var float lastOBHighB = na
var float lastOBLowB = na
var int lastOBBarB = na

var float lastOBHighS = na
var float lastOBLowS = na
var int lastOBBarS = na

var int lastSSLBar = na
var int lastBSLBar = na

// ============================================================================
// DETECT SWING HIGHS & LOWS
// ============================================================================

f_detectSwings() =>
    p = swingWindow
    
    if bar_index >= p * 2
        isHigh = true
        for j = 1 to p
            if high[j] > high[0] or high[j] >= high[0]
                isHigh := false
                break
        
        if isHigh
            array.push(swingHighs, chart.point.new(x=bar_index, y=high[0]))
        
        isLow = true
        for j = 1 to p
            if low[j] < low[0] or low[j] <= low[0]
                isLow := false
                break
        
        if isLow
            array.push(swingLows, chart.point.new(x=bar_index, y=low[0]))
    
    if array.size(swingHighs) > 100
        array.shift(swingHighs)
    if array.size(swingLows) > 100
        array.shift(swingLows)

// ============================================================================
// DETECT FAIR VALUE GAPS (FVG)
// ============================================================================

f_detectFVGs() =>
    bullishFVG = false
    bearishFVG = false
    fvgTopB = na
    fvgBotB = na
    fvgTopS = na
    fvgBotS = na
    
    if bar_index >= 2
        // Bullish FVG
        if high[2] < low[0] and close[1] > open[1]
            bullishFVG := true
            fvgBotB := high[2]
            fvgTopB := low[0]
            lastFVGBarB := bar_index
            lastFVGTop := fvgTopB
            lastFVGBot := fvgBotB
        
        // Bearish FVG
        if low[2] > high[0] and close[1] < open[1]
            bearishFVG := true
            fvgTopS := low[2]
            fvgBotS := high[0]
            lastFVGBarS := bar_index
            lastFVGTopS := fvgTopS
            lastFVGBotS := fvgBotS
    
    [bullishFVG, bearishFVG, fvgTopB, fvgBotB, fvgTopS, fvgBotS]

// ============================================================================
// DETECT ORDER BLOCKS (OB)
// ============================================================================

f_detectOrderBlocks() =>
    bullishOB = false
    bearishOB = false
    obHighB = 0.0
    obLowB = 0.0
    obHighS = 0.0
    obLowS = 0.0
    
    if bar_index >= 2
        // Bullish OB (Bearish candle before bullish expansion)
        if close[1] < open[1] and high[2] < low[0]
            bullishOB := true
            obHighB := high[1]
            obLowB := low[1]
            lastOBBarB := bar_index - 1
            lastOBHighB := obHighB
            lastOBLowB := obLowB
        
        // Bearish OB (Bullish candle before bearish collapse)
        if close[1] > open[1] and low[2] > high[0]
            bearishOB := true
            obHighS := high[1]
            obLowS := low[1]
            lastOBBarS := bar_index - 1
            lastOBHighS := obHighS
            lastOBLowS := obLowS
    
    [bullishOB, bearishOB, obHighB, obLowB, obHighS, obLowS]

// ============================================================================
// DETECT LIQUIDITY SWEEPS
// ============================================================================

f_detectSweeps() =>
    sslSweep = false
    bslSweep = false
    
    if array.size(swingHighs) > 0
        recentHigh = array.get(swingHighs, array.size(swingHighs) - 1)
        if not na(recentHigh.y) and bar_index - recentHigh.x > 1 and bar_index - recentHigh.x < 60
            if high > recentHigh.y and close <= recentHigh.y
                bslSweep := true
                lastBSLBar := bar_index
    
    if array.size(swingLows) > 0
        recentLow = array.get(swingLows, array.size(swingLows) - 1)
        if not na(recentLow.y) and bar_index - recentLow.x > 1 and bar_index - recentLow.x < 60
            if low < recentLow.y and close >= recentLow.y
                sslSweep := true
                lastSSLBar := bar_index
    
    [sslSweep, bslSweep]

// ============================================================================
// DETECT BOS & CHOCH
// ============================================================================

f_detectStructures() =>
    if array.size(swingHighs) > 0 and array.size(swingLows) > 0
        recentHighs = array.new<chart.point>()
        recentLows = array.new<chart.point>()
        
        for i = 0 to math.min(array.size(swingHighs) - 1, 30)
            sh = array.get(swingHighs, array.size(swingHighs) - 1 - i)
            if bar_index - sh.x < lookbackWindow and bar_index - sh.x > 0
                array.push(recentHighs, sh)
        
        for i = 0 to math.min(array.size(swingLows) - 1, 30)
            sl = array.get(swingLows, array.size(swingLows) - 1 - i)
            if bar_index - sl.x < lookbackWindow and bar_index - sl.x > 0
                array.push(recentLows, sl)
        
        if array.size(recentHighs) > 0
            highestRecent = array.get(recentHighs, 0)
            for i = 1 to array.size(recentHighs) - 1
                candidate = array.get(recentHighs, i)
                if candidate.y > highestRecent.y
                    highestRecent := candidate
            lastHighTarget := highestRecent.y
        
        if array.size(recentLows) > 0
            lowestRecent = array.get(recentLows, 0)
            for i = 1 to array.size(recentLows) - 1
                candidate = array.get(recentLows, i)
                if candidate.y < lowestRecent.y
                    lowestRecent := candidate
            lastLowTarget := lowestRecent.y
        
        // Bullish BOS/CHOCH
        if not na(lastHighTarget) and close > lastHighTarget
            if marketTrend == "BEARISH"
                lastWasBullishChoch := true
                marketTrend := "BULLISH"
            else
                lastWasBullishBOS := true
            lastHighTarget := na
        
        // Bearish BOS/CHOCH
        if not na(lastLowTarget) and close < lastLowTarget
            if marketTrend == "BULLISH"
                lastWasBearishChoch := true
                marketTrend := "BEARISH"
            else
                lastWasBearishBOS := true
            lastLowTarget := na

// ============================================================================
// DETECT EQUAL HIGHS & LOWS
// ============================================================================

f_detectEqualPrices() =>
    eqhPrice = 0.0
    eqlPrice = 0.0
    hasEQH = false
    hasEQL = false
    
    if array.size(swingHighs) > 1
        for i = 0 to math.min(array.size(swingHighs) - 2, 20)
            h1 = array.get(swingHighs, i)
            if i + 1 < array.size(swingHighs)
                h2 = array.get(swingHighs, i + 1)
                
                if h2.x - h1.x <= lookbackWindow and h2.x - h1.x > 0
                    avg = (h1.y + h2.y) / 2
                    pctDiff = math.abs(h1.y - h2.y) / avg
                    
                    if pctDiff < eqhEqlThreshold
                        eqhPrice := avg
                        hasEQH := true
                        break
    
    if array.size(swingLows) > 1
        for i = 0 to math.min(array.size(swingLows) - 2, 20)
            l1 = array.get(swingLows, i)
            if i + 1 < array.size(swingLows)
                l2 = array.get(swingLows, i + 1)
                
                if l2.x - l1.x <= lookbackWindow and l2.x - l1.x > 0
                    avg = (l1.y + l2.y) / 2
                    pctDiff = math.abs(l1.y - l2.y) / avg
                    
                    if pctDiff < eqhEqlThreshold
                        eqlPrice := avg
                        hasEQL := true
                        break
    
    [hasEQH, hasEQL, eqhPrice, eqlPrice]

// ============================================================================
// GENERATE TRADING SIGNALS
// ============================================================================

f_generateSignals(sslSweep, bslSweep, bullishOB, bearishOB, obHighB, obLowB, obHighS, obLowS) =>
    if not buyActive and sslSweep and lastWasBullishChoch and bullishOB and low <= obHighB and high >= obLowB
        entry = close
        sl = obLowB * 0.9985
        tp = entry + (entry - sl) * prefRR
        rr = (entry - sl) / (tp - entry)
        
        if rr >= minRR and rr <= 10
            lastBuyEntry := entry
            lastBuySL := sl
            lastBuyTP := tp
            lastBuyRR := rr
            lastBuyBar := bar_index
            buyActive := true
            lastWasBullishChoch := false
    
    if not sellActive and bslSweep and lastWasBearishChoch and bearishOB and low <= obHighS and high >= obLowS
        entry = close
        sl = obHighS * 1.0015
        tp = entry - (sl - entry) * prefRR
        rr = (sl - entry) / (entry - tp)
        
        if rr >= minRR and rr <= 10
            lastSellEntry := entry
            lastSellSL := sl
            lastSellTP := tp
            lastSellRR := rr
            lastSellBar := bar_index
            sellActive := true
            lastWasBearishChoch := false

// ============================================================================
// CHECK EXIT CONDITIONS
// ============================================================================

f_checkExits() =>
    if buyActive
        if close < lastBuySL
            buyActive := false
        
        if close > lastBuyTP
            buyActive := false
        
        if marketTrend == "BEARISH"
            buyActive := false
    
    if sellActive
        if close > lastSellSL
            sellActive := false
        
        if close < lastSellTP
            sellActive := false
        
        if marketTrend == "BULLISH"
            sellActive := false

// ============================================================================
// EXECUTE DETECTION
// ============================================================================

f_detectSwings()
[bullishFVG, bearishFVG, fvgTopB, fvgBotB, fvgTopS, fvgBotS] = f_detectFVGs()
[bullishOB, bearishOB, obHighB, obLowB, obHighS, obLowS] = f_detectOrderBlocks()
[sslSweep, bslSweep] = f_detectSweeps()
f_detectStructures()
[hasEQH, hasEQL, eqhPrice, eqlPrice] = f_detectEqualPrices()
f_generateSignals(sslSweep, bslSweep, bullishOB, bearishOB, obHighB, obLowB, obHighS, obLowS)
f_checkExits()

// ============================================================================
// DRAWING: SWING POINTS
// ============================================================================

if showSwings
    if array.size(swingHighs) > 0
        for i = math.max(0, array.size(swingHighs) - 20) to array.size(swingHighs) - 1
            sh = array.get(swingHighs, i)
            label.new(x=sh.x, y=sh.y, text="H", color=color.new(color.green, 0), style=label.style_diamond, size=size.tiny, textcolor=color.white)
    
    if array.size(swingLows) > 0
        for i = math.max(0, array.size(swingLows) - 20) to array.size(swingLows) - 1
            sl = array.get(swingLows, i)
            label.new(x=sl.x, y=sl.y, text="L", color=color.new(color.red, 0), style=label.style_diamond, size=size.tiny, textcolor=color.white)

// ============================================================================
// DRAWING: FVG
// ============================================================================

if showFVG
    if not na(lastFVGBarB) and bar_index - lastFVGBarB < 100 and not na(lastFVGTop) and not na(lastFVGBot)
        box.new(left=lastFVGBarB - 1, top=lastFVGTop, right=bar_index + 20, bottom=lastFVGBot, bgcolor=color.new(color.green, 85), border_color=na)
    
    if not na(lastFVGBarS) and bar_index - lastFVGBarS < 100 and not na(lastFVGTopS) and not na(lastFVGBotS)
        box.new(left=lastFVGBarS - 1, top=lastFVGTopS, right=bar_index + 20, bottom=lastFVGBotS, bgcolor=color.new(color.red, 85), border_color=na)

// ============================================================================
// DRAWING: ORDER BLOCKS
// ============================================================================

if showOB
    if not na(lastOBBarB) and bar_index - lastOBBarB < 100 and not na(lastOBHighB) and not na(lastOBLowB)
        box.new(left=lastOBBarB, top=lastOBHighB, right=bar_index + 50, bottom=lastOBLowB, bgcolor=color.new(color.blue, 80), border_color=na)
    
    if not na(lastOBBarS) and bar_index - lastOBBarS < 100 and not na(lastOBHighS) and not na(lastOBLowS)
        box.new(left=lastOBBarS, top=lastOBHighS, right=bar_index + 50, bottom=lastOBLowS, bgcolor=color.new(color.orange, 80), border_color=na)

// ============================================================================
// DRAWING: STRUCTURES (BOS/CHOCH)
// ============================================================================

if showStructure
    if lastWasBullishChoch and not na(lastHighTarget)
        line.new(x1=bar_index - 30, y1=lastHighTarget, x2=bar_index, y2=lastHighTarget, color=color.new(color.green, 0), width=2, style=line.style_dashed)
    
    if lastWasBearishChoch and not na(lastLowTarget)
        line.new(x1=bar_index - 30, y1=lastLowTarget, x2=bar_index, y2=lastLowTarget, color=color.new(color.red, 0), width=2, style=line.style_dashed)

// ============================================================================
// DRAWING: SWEEPS
// ============================================================================

if showSweeps
    if not na(lastSSLBar) and bar_index - lastSSLBar < 50
        label.new(x=lastSSLBar, y=low + (high - low) * 0.5, text="SSL", color=color.new(color.lime, 0), style=label.style_label_down, size=size.small, textcolor=color.black)
    
    if not na(lastBSLBar) and bar_index - lastBSLBar < 50
        label.new(x=lastBSLBar, y=high - (high - low) * 0.5, text="BSL", color=color.new(color.purple, 0), style=label.style_label_up, size=size.small, textcolor=color.white)

// ============================================================================
// DRAWING: EQUAL HIGHS & LOWS
// ============================================================================

if showEQ
    if hasEQH
        line.new(x1=bar_index - 50, y1=eqhPrice, x2=bar_index, y2=eqhPrice, color=color.new(color.green, 40), width=1, style=line.style_dotted)
    
    if hasEQL
        line.new(x1=bar_index - 50, y1=eqlPrice, x2=bar_index, y2=eqlPrice, color=color.new(color.red, 40), width=1, style=line.style_dotted)

// ============================================================================
// DRAWING: TRADE SIGNALS
// ============================================================================

if showSignals
    if buyActive
        label.new(x=lastBuyBar, y=lastBuySL - (lastBuySL - lastBuyEntry) * 0.1, text="BUY\n" + str.tostring(lastBuyEntry, "0.00000"), color=color.new(color.green, 0), style=label.style_label_up, size=size.small, textcolor=color.white)
        line.new(x1=lastBuyBar, y1=lastBuySL, x2=bar_index, y2=lastBuySL, color=color.new(color.red, 0), width=1, style=line.style_dashed)
        line.new(x1=lastBuyBar, y1=lastBuyTP, x2=bar_index, y2=lastBuyTP, color=color.new(color.green, 0), width=1, style=line.style_dashed)
    
    if sellActive
        label.new(x=lastSellBar, y=lastSellSL + (lastSellSL - lastSellEntry) * 0.1, text="SELL\n" + str.tostring(lastSellEntry, "0.00000"), color=color.new(color.red, 0), style=label.style_label_down, size=size.small, textcolor=color.white)
        line.new(x1=lastSellBar, y1=lastSellSL, x2=bar_index, y2=lastSellSL, color=color.new(color.red, 0), width=1, style=line.style_dashed)
        line.new(x1=lastSellBar, y1=lastSellTP, x2=bar_index, y2=lastSellTP, color=color.new(color.green, 0), width=1, style=line.style_dashed)

// ============================================================================
// ALERTS
// ============================================================================

if buyActive and barstate.isconfirmed
    alert("BUY: Entry=" + str.tostring(lastBuyEntry, "0.00000") + " SL=" + str.tostring(lastBuySL, "0.00000") + " TP=" + str.tostring(lastBuyTP, "0.00000") + " RR=" + str.tostring(lastBuyRR, "0.00"), alert.freq_once_per_bar)

if sellActive and barstate.isconfirmed
    alert("SELL: Entry=" + str.tostring(lastSellEntry, "0.00000") + " SL=" + str.tostring(lastSellSL, "0.00000") + " TP=" + str.tostring(lastSellTP, "0.00000") + " RR=" + str.tostring(lastSellRR, "0.00"), alert.freq_once_per_bar)

if lastWasBullishChoch and barstate.isconfirmed
    alert("Bullish CHOCH", alert.freq_once_per_bar)

if lastWasBearishChoch and barstate.isconfirmed
    alert("Bearish CHOCH", alert.freq_once_per_bar)

if sslSweep and barstate.isconfirmed
    alert("SSL Sweep Detected", alert.freq_once_per_bar)

if bslSweep and barstate.isconfirmed
    alert("BSL Sweep Detected", alert.freq_once_per_bar)

// ============================================================================
// INFO TABLE
// ============================================================================

if showTable
    var table infoTable = table.new(position=position.top_right, columns=2, rows=10, bgcolor=color.new(color.black, 80), border_color=color.gray, frame_color=color.gray)
    
    table.cell(infoTable, column=0, row=0, text="SMC ENGINE", text_color=color.white, bgcolor=color.new(color.blue, 50))
    table.cell(infoTable, column=1, row=0, text="Status", text_color=color.white, bgcolor=color.new(color.blue, 50))
    
    table.cell(infoTable, column=0, row=1, text="Trend", text_color=color.white)
    table.cell(infoTable, column=1, row=1, text=marketTrend, text_color=marketTrend=="BULLISH"?color.green:color.red)
    
    table.cell(infoTable, column=0, row=2, text="Buy Active", text_color=color.white)
    table.cell(infoTable, column=1, row=2, text=buyActive?"YES":"NO", text_color=buyActive?color.green:color.gray)
    
    table.cell(infoTable, column=0, row=3, text="Entry", text_color=color.white)
    table.cell(infoTable, column=1, row=3, text=buyActive?str.tostring(lastBuyEntry, "0.00000"):"-", text_color=color.white)
    
    table.cell(infoTable, column=0, row=4, text="SL", text_color=color.white)
    table.cell(infoTable, column=1, row=4, text=buyActive?str.tostring(lastBuySL, "0.00000"):"-", text_color=color.red)
    
    table.cell(infoTable, column=0, row=5, text="TP", text_color=color.white)
    table.cell(infoTable, column=1, row=5, text=buyActive?str.tostring(lastBuyTP, "0.00000"):"-", text_color=color.green)
    
    table.cell(infoTable, column=0, row=6, text="RR", text_color=color.white)
    table.cell(infoTable, column=1, row=6, text=buyActive?str.tostring(lastBuyRR, "0.00"):"-", text_color=color.yellow)
    
    table.cell(infoTable, column=0, row=7, text="Swings", text_color=color.white)
    table.cell(infoTable, column=1, row=7, text="H:" + str.tostring(array.size(swingHighs)) + " L:" + str.tostring(array.size(swingLows)), text_color=color.white)
    
    table.cell(infoTable, column=0, row=8, text="Last Sweep", text_color=color.white)
    table.cell(infoTable, column=1, row=8, text=not na(lastSSLBar)?"SSL":not na(lastBSLBar)?"BSL":"-", text_color=color.white)
    
    table.cell(infoTable, column=0, row=9, text="Last Structure", text_color=color.white)
    table.cell(infoTable, column=1, row=9, text=lastWasBullishChoch?"B.CHOCH":lastWasBearishChoch?"S.CHOCH":lastWasBullishBOS?"B.BOS":lastWasBearishBOS?"S.BOS":"-", text_color=color.white)
